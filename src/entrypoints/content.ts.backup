import '~/assets/fonts/fonts.css';
import '../styles/content.css';
import { browser } from 'wxt/browser';

export default defineContentScript({
  matches: ['<all_urls>'],
  main() {
    let activeInput: HTMLElement | null = null;
    let iconContainer: HTMLDivElement | null = null;
    let popup: HTMLDivElement | null = null;
    let typingTimer: number | null = null;
    let isTyping = false;
    let isComposing = false;
    let lastTypingTime = 0;
    let typingSpeedHistory: number[] = [];
    let cachedPosition: { left: number; top: number } | null = null;
    let lastInputRect: DOMRect | null = null;

    // Enhanced element detection function
    function isEditableElement(element: HTMLElement): boolean {
      // Check for standard input types
      if (element.tagName === 'INPUT') {
        const inputType = (element as HTMLInputElement).type;
        return ['text', 'email', 'search', 'url', 'tel', 'password'].includes(inputType);
      }

      // Check for textarea
      if (element.tagName === 'TEXTAREA') {
        return true;
      }

      // Check for contenteditable elements
      if (element.isContentEditable) {
        return true;
      }

      // Check for specific roles that might be editable
      const role = element.getAttribute('role');
      if (role === 'textbox' || role === 'combobox') {
        return true;
      }

      // Check for data attributes that indicate editability
      if (element.hasAttribute('data-editable') || element.hasAttribute('data-contenteditable')) {
        return true;
      }

      return false;
    }

    // Calculate adaptive debounce time based on typing speed
    function getAdaptiveDebounceTime(): number {
      if (typingSpeedHistory.length < 3) {
        return 150; // Default debounce time
      }

      const avgSpeed = typingSpeedHistory.reduce((a, b) => a + b, 0) / typingSpeedHistory.length;
      const now = Date.now();

      // If typing very fast (< 100ms between keystrokes), use shorter debounce
      if (avgSpeed < 100) {
        return 50;
      }
      // If typing moderately fast (100-200ms), use medium debounce
      else if (avgSpeed < 200) {
        return 100;
      }
      // If typing slowly (> 200ms), use longer debounce to avoid flickering
      else {
        return 200;
      }
    }

    // Check if key event represents significant text input
    function isSignificantKeyEvent(event: KeyboardEvent): boolean {
      // Ignore modifier keys when pressed alone
      if (['Shift', 'Control', 'Alt', 'Meta', 'CapsLock', 'Tab'].includes(event.key)) {
        return false;
      }

      // Ignore navigation keys
      if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'Home', 'End', 'PageUp', 'PageDown'].includes(event.key)) {
        return false;
      }

      // Ignore function keys
      if (event.key.startsWith('F') && event.key.length <= 3 && /^\d+$/.test(event.key.substring(1))) {
        return false;
      }

      // Ignore specific control combinations that don't add text
      if (event.ctrlKey || event.metaKey) {
        if (['a', 'c', 'v', 'x', 'z', 'y', 's', 'f', 'r', 'n', 't', 'w'].includes(event.key.toLowerCase())) {
          return false;
        }
      }

      return true;
    }

    // Helper function to escape HTML
    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Tokenize text into words for word-level diff
    function tokenize(text: string): string[] {
      // Split by whitespace but preserve original whitespace for display
      return text.split(/(\s+)/).filter(token => token.length > 0);
    }

    // Generate word-level diff operations between two texts
    function diffTexts(oldText: string, newText: string): { type: 'equal' | 'insert' | 'delete', text: string }[] {
      const oldWords = tokenize(oldText);
      const newWords = tokenize(newText);

      // Create a matrix for dynamic programming
      const dp: number[][] = Array(oldWords.length + 1).fill(null).map(() => Array(newWords.length + 1).fill(0));

      // Initialize base cases
      for (let i = 0; i <= oldWords.length; i++) {
        dp[i][0] = i;
      }
      for (let j = 0; j <= newWords.length; j++) {
        dp[0][j] = j;
      }

      // Fill DP table
      for (let i = 1; i <= oldWords.length; i++) {
        for (let j = 1; j <= newWords.length; j++) {
          if (oldWords[i - 1] === newWords[j - 1]) {
            dp[i][j] = dp[i - 1][j - 1];
          } else {
            dp[i][j] = Math.min(
              dp[i - 1][j] + 1,     // deletion
              dp[i][j - 1] + 1,     // insertion
              dp[i - 1][j - 1] + 1  // substitution
            );
          }
        }
      }

      // Backtrack to generate operations
      const operations: { type: 'equal' | 'insert' | 'delete', text: string }[] = [];
      let i = oldWords.length;
      let j = newWords.length;

      while (i > 0 || j > 0) {
        if (i > 0 && j > 0 && oldWords[i - 1] === newWords[j - 1]) {
          operations.unshift({ type: 'equal', text: oldWords[i - 1] });
          i--;
          j--;
        } else if (i > 0 && j > 0 && dp[i][j] === dp[i - 1][j - 1] + 1) {
          // Substitution - treat as delete + insert
          operations.unshift({ type: 'delete', text: oldWords[i - 1] });
          operations.unshift({ type: 'insert', text: newWords[j - 1] });
          i--;
          j--;
        } else if (i > 0 && dp[i][j] === dp[i - 1][j] + 1) {
          operations.unshift({ type: 'delete', text: oldWords[i - 1] });
          i--;
        } else if (j > 0 && dp[i][j] === dp[i][j - 1] + 1) {
          operations.unshift({ type: 'insert', text: newWords[j - 1] });
          j--;
        }
      }

      return operations;
    }

    // Generate HTML with highlighted differences
    function generateDiffHtml(oldText: string, newText: string): string {
      const operations = diffTexts(oldText, newText);
      let html = '<div class="diff-words-container">';

      // Group operations by words
      const wordGroups: { original: string[], corrected: string[] }[] = [];
      let currentOriginal: string[] = [];
      let currentCorrected: string[] = [];

      for (const op of operations) {
        // Check if the token is whitespace
        const isWhitespace = /\s+/.test(op.text);

        if (op.type === 'equal') {
          // If we have pending changes, save them as a group
          if (currentOriginal.length > 0 || currentCorrected.length > 0) {
            wordGroups.push({
              original: [...currentOriginal],
              corrected: [...currentCorrected]
            });
            currentOriginal = [];
            currentCorrected = [];
          }

          // Add unchanged token (word or whitespace) as its own group
          if (isWhitespace) {
            // For whitespace, just add it directly without grouping
            wordGroups.push({
              original: [op.text],
              corrected: [op.text]
            });
          } else {
            // For words, add as a group
            wordGroups.push({
              original: [op.text],
              corrected: [op.text]
            });
          }
        } else if (op.type === 'delete') {
          currentOriginal.push(op.text);
        } else if (op.type === 'insert') {
          currentCorrected.push(op.text);
        }
      }

      // Handle any remaining changes
      if (currentOriginal.length > 0 || currentCorrected.length > 0) {
        wordGroups.push({
          original: [...currentOriginal],
          corrected: [...currentCorrected]
        });
      }

      // Generate HTML for each word group
      for (const group of wordGroups) {
        const originalText = group.original.join('');
        const correctedText = group.corrected.join('');

        // Check if this group contains only whitespace
        const isWhitespaceGroup = /\s+/.test(originalText) && originalText === correctedText;

        if (isWhitespaceGroup) {
          // Handle whitespace - <pre> will preserve it naturally
          html += escapeHtml(originalText);
        } else if (originalText === correctedText) {
          // No change - display normally
          html += `<span class="grammar-unchanged">${escapeHtml(originalText)}</span>`;
        } else {
          // Change detected - display with original and corrected versions side by side
          html += `<span class="word-diff-group"><span class="original-word">${escapeHtml(originalText)}</span><span class="corrected-word">${escapeHtml(correctedText)}</span></span>`;
        }
      }

      html += '</div>';
      return html;
    }

    // Create the floating icon
    function createIcon() {
      if (iconContainer) return;

      iconContainer = document.createElement('div');
      iconContainer.className = 'safetyper-icon';
      iconContainer.innerHTML = `
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="10" cy="10" r="9" stroke="#4A90E2" stroke-width="2" fill="white"/>
          <path d="M6 8.5C6 8.5 8 6 10 6C12 6 14 8.5 14 8.5" stroke="#4A90E2" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M10 10V14" stroke="#4A90E2" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="10" cy="14" r="0.5" fill="#4A90E2"/>
        </svg>
      `;
      iconContainer.addEventListener('click', showPopup);
      document.body.appendChild(iconContainer);
    }

    // Position icon near the active input with improved performance
    function positionIcon(element: HTMLElement) {
      if (!iconContainer) return;

      const rect = element.getBoundingClientRect();

      // Check if position has actually changed to avoid unnecessary DOM updates
      if (lastInputRect &&
          Math.abs(lastInputRect.left - rect.left) < 1 &&
          Math.abs(lastInputRect.top - rect.top) < 1 &&
          Math.abs(lastInputRect.width - rect.width) < 1 &&
          Math.abs(lastInputRect.height - rect.height) < 1) {
        return; // Position hasn't changed significantly
      }

      lastInputRect = rect;

      const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      const newLeft = rect.right + scrollLeft - 30;
      const newTop = rect.bottom + scrollTop - 30;

      // Only update DOM if position actually changed
      if (!cachedPosition || cachedPosition.left !== newLeft || cachedPosition.top !== newTop) {
        iconContainer.style.left = `${newLeft}px`;
        iconContainer.style.top = `${newTop}px`;
        cachedPosition = { left: newLeft, top: newTop };
      }

      iconContainer.style.display = 'flex';
    }

    // Reposition icon on window resize
    function repositionIconOnResize() {
      if (activeInput && iconContainer && iconContainer.style.display !== 'none') {
        positionIcon(activeInput);
      }
    }

    // Hide the icon
    function hideIcon() {
      if (iconContainer) {
        iconContainer.style.display = 'none';
      }
    }

    // Show grammar check popup
    function showPopup(e: Event) {
      e.stopPropagation();

      if (popup) {
        popup.remove();
        popup = null;
        return;
      }

      popup = document.createElement('div');
      popup.className = 'safetyper-popup';
      popup.innerHTML = `
        <div class="draggable-indicator">drag me</div>
        <div class="safetyper-popup-content">
          <div class="loading">Loading...</div>
        </div>
      `;

      // Position popup near the icon and ensure it fits within screen boundaries
      if (iconContainer) {
        const iconRect = iconContainer.getBoundingClientRect();
        const popupWidth = 450; // Approximate width
        const popupHeight = 200; // Approximate height

        // Calculate initial position
        let left = iconRect.left - 200;
        let top = iconRect.bottom + 10;

        // Get viewport dimensions
        const viewportWidth = window.innerWidth;
        const viewportHeight = window.innerHeight;

        // Adjust position if popup would go off screen
        if (left + popupWidth > viewportWidth) {
          left = viewportWidth - popupWidth - 10; // 10px padding from right edge
        }

        if (left < 0) {
          left = 10; // 10px padding from left edge
        }

        if (top + popupHeight > viewportHeight) {
          // Position above the icon if there's not enough space below
          top = iconRect.top - popupHeight - 10;
        }

        if (top < 0) {
          top = 10; // 10px padding from top edge
        }

        popup.style.left = `${left}px`;
        popup.style.top = `${top}px`;
      }

      document.body.appendChild(popup);

      // Make popup draggable
      makePopupDraggable(popup);

      // Check if API key exists and update popup content
      browser.storage.local.get(['openRouterKey']).then((result) => {
        const hasApiKey = !!result.openRouterKey;

        if (popup) {
          const content = popup.querySelector('.safetyper-popup-content');
          if (content) {
            if (hasApiKey) {
              content.innerHTML = `
                <button class="safetyper-check-btn">Check Grammar</button>
                <button class="safetyper-settings-btn">Settings</button>
              `;

              // Add event listener to check button
              const checkBtn = content.querySelector('.safetyper-check-btn');
              if (checkBtn) {
                checkBtn.addEventListener('click', handleGrammarCheck);
              }
            } else {
              content.innerHTML = `
                <p class="error">Please set your OpenRouter API key in the settings.</p>
                <button class="safetyper-settings-btn">Open Settings</button>
              `;
            }

            // Add event listener to settings button
            const settingsBtn = content.querySelector('.safetyper-settings-btn');
            if (settingsBtn) {
              settingsBtn.addEventListener('click', openSettings);
            }
          }
        }
      });

      // Close popup when clicking outside
      setTimeout(() => {
        document.addEventListener('click', (e) => {
          // Don't close popup if we're currently checking grammar
          if (popup && popup.querySelector('.loading')) {
            return;
          }
          // Don't close popup if clicking on close button (let the button handler do it)
          const target = e.target as Element;
          if (target.classList.contains('safetyper-close-btn')) {
            return;
          }
          // Close popup if clicking outside
          if (popup && !popup.contains(e.target as Node)) {
            closePopup();
          }
        });
      }, 0);
    }

    // Make popup draggable
    function makePopupDraggable(popupElement: HTMLDivElement) {
      let isDragging = false;
      let initialX: number;
      let initialY: number;
      let initialLeft: number;
      let initialTop: number;

      // Make the whole popup draggable
      popupElement.addEventListener('mousedown', dragStart);
      document.addEventListener('mouseup', dragEnd);
      document.addEventListener('mousemove', drag);

      function dragStart(e: MouseEvent) {
        // Don't start dragging if clicking on buttons or interactive elements
        const target = e.target as Element;
        if (target.tagName === 'BUTTON' || target.tagName === 'A' || target.tagName === 'INPUT') {
          return;
        }

        isDragging = true;
        initialX = e.clientX;
        initialY = e.clientY;
        initialLeft = parseInt(popupElement.style.left) || 0;
        initialTop = parseInt(popupElement.style.top) || 0;

        popupElement.style.cursor = 'grabbing';
        e.preventDefault(); // Prevent text selection
      }

      function dragEnd() {
        isDragging = false;
        popupElement.style.cursor = 'default';
      }

      function drag(e: MouseEvent) {
        if (isDragging) {
          e.preventDefault();

          const currentX = e.clientX - initialX;
          const currentY = e.clientY - initialY;

          let newLeft = initialLeft + currentX;
          let newTop = initialTop + currentY;

          // Ensure popup stays within viewport bounds
          const popupRect = popupElement.getBoundingClientRect();
          const viewportWidth = window.innerWidth;
          const viewportHeight = window.innerHeight;

          // Constrain horizontal movement
          if (newLeft < 0) {
            newLeft = 0;
          } else if (newLeft + popupRect.width > viewportWidth) {
            newLeft = viewportWidth - popupRect.width;
          }

          // Constrain vertical movement
          if (newTop < 0) {
            newTop = 0;
          } else if (newTop + popupRect.height > viewportHeight) {
            newTop = viewportHeight - popupRect.height;
          }

          popupElement.style.left = `${newLeft}px`;
          popupElement.style.top = `${newTop}px`;
        }
      }
    }

    // Open extension settings popup
    function openSettings() {
      closePopup();
      // Open the extension popup by sending a message to the background script
      browser.runtime.sendMessage({ action: 'openPopup' });
    }

    function closePopup() {
      // Don't close popup if we're currently checking grammar
      if (popup && popup.querySelector('.loading')) {
        return;
      }

      if (popup) {
        popup.remove();
        popup = null;
      }
      document.removeEventListener('click', closePopup as EventListener);
    }

    function handleGrammarCheck() {
      if (!activeInput) return;

      const text = (activeInput as HTMLInputElement).value ||
        (activeInput as HTMLTextAreaElement).value ||
        activeInput.textContent || '';

      if (!text.trim()) {
        alert('Please enter some text to check grammar.');
        return;
      }

      // Show loading state
      if (popup) {
        const content = popup.querySelector('.safetyper-popup-content');
        if (content) {
          content.innerHTML = `
            <div class="loading">Checking grammar...</div>
          `;
        }
      }

      // Get selected model from storage
      browser.storage.local.get(['selectedModel']).then(async (result) => {
        const model = result.selectedModel || 'openai/gpt-3.5-turbo';

        try {
          // Call OpenRouter API for grammar check through background script
          // Note: API key is retrieved securely by the background script
          const response = await browser.runtime.sendMessage({
            action: 'checkGrammar',
            referer: window.location.href,
            payload: {
              model: model,
              messages: [
                {
                  role: "system",
                  content: "You are a grammar checking assistant. Fix grammar and spelling errors in the provided text. Return ONLY the corrected text with EXACTLY the same formatting, line breaks, paragraphs, and whitespace as the original. Do not add, remove, or modify any line breaks, indentation, spacing, or paragraph structure. Preserve every newline character and whitespace character exactly as they appear in the original. Do not wrap the response in quotes or add any prefixes or explanations."
                },
                {
                  role: "user",
                  content: `Please fix the grammar and spelling in this text while preserving EXACTLY the same formatting, line breaks, and structure as the original: "${text}"`
                }
              ],
              temperature: 0.3,
              response_format: { type: "text" }
            }
          });

          if (!response.success) {
            // Handle API key not configured error specifically
            if (response.error === 'API key not configured' || response.error === 'Invalid API key format') {
              if (popup) {
                const content = popup.querySelector('.safetyper-popup-content');
                if (content) {
                  content.innerHTML = `
                    <p class="error">API key not configured or invalid. Please set your OpenRouter API key in the settings.</p>
                    <button class="safetyper-settings-btn">Open Settings</button>
                  `;

                  const settingsBtn = content.querySelector('.safetyper-settings-btn');
                  if (settingsBtn) {
                    settingsBtn.addEventListener('click', openSettings);
                  }
                }
              }
              return;
            }
            throw new Error(response.error || 'Unknown error');
          }

          const data = response.data;
          let correctedText = text;

          // Extract the corrected text from the response
          if (data.choices && data.choices.length > 0) {
            const choice = data.choices[0];
            if (choice.message && choice.message.content) {
              // Remove only leading/trailing whitespace from the entire response,
              // but preserve internal formatting
              const rawCorrected = choice.message.content;
              const trimmedCorrected = rawCorrected.trim();

              // If the response has the same number of lines as the original,
              // preserve the line structure
              const originalLines = text.split('\n');
              const correctedLines = trimmedCorrected.split('\n');

              if (originalLines.length === correctedLines.length) {
                // Same number of lines, preserve exact line breaks
                correctedText = trimmedCorrected;
              } else {
                // Different number of lines, fall back to original logic
                correctedText = trimmedCorrected;
              }
            }
          }

          // Display results in popup with diff highlighting
          if (popup) {
            const content = popup.querySelector('.safetyper-popup-content');
            if (content) {
              // Check if there were no changes
              if (text.trim() === correctedText.trim()) {
                content.innerHTML = `
                  <div class="results-container">
                    <div class="no-changes-message">
                      <p>Congratulations! This sentence is correct.</p>
                    </div>
                    <button class="safetyper-close-btn">Close</button>
                  </div>
                `;
               } else {
                 // Detect if this is a complex editor like Draft.js
                 const isComplexEditor = activeInput && activeInput.contentEditable === 'true' &&
                   activeInput.classList.contains('public-DraftEditor-content');

                 let buttonsHtml = '';
                 if (isComplexEditor) {
                   // Complex editor: only show copy button
                   buttonsHtml = '<button class="safetyper-copy-btn">Copy to Clipboard</button>';
                 } else {
                   // Simple input: show both apply and copy buttons
                   buttonsHtml = `
                     <div class="button-group">
                       <button class="safetyper-apply-btn">Apply Changes</button>
                       <button class="safetyper-copy-btn">Copy to Clipboard</button>
                     </div>
                   `;
                 }

                 const instructions = isComplexEditor ?
                   '<p class="editor-instruction">Complex editor detected. Copy the text and paste it manually to preserve formatting.</p>' : '';

                 content.innerHTML = `
                   <div class="results-container">
                     <div class="diff-container">
                       <h4>Changes:</h4>
                       <div class="diff-text">${generateDiffHtml(text, correctedText)}</div>
                       ${instructions}
                     </div>
                     ${buttonsHtml}
                     <button class="safetyper-close-btn">Close</button>
                   </div>
                 `;
               }

               const applyBtn = content.querySelector('.safetyper-apply-btn');
               const copyBtn = content.querySelector('.safetyper-copy-btn');
               const closeBtn = content.querySelector('.safetyper-close-btn');

               // Handle apply button (only for simple inputs)
               if (applyBtn) {
                 applyBtn.addEventListener('click', () => {
                   if (activeInput) {
                     if (activeInput instanceof HTMLInputElement || activeInput instanceof HTMLTextAreaElement) {
                       activeInput.value = correctedText;
                     } else if (activeInput.contentEditable === 'true') {
                       // For contenteditable elements
                       try {
                         activeInput.focus();
                         const selection = window.getSelection();
                         const range = document.createRange();
                         range.selectNodeContents(activeInput);
                         selection?.removeAllRanges();
                         selection?.addRange(range);
                         document.execCommand('insertText', false, correctedText);
                       } catch (error) {
                         console.warn('Contenteditable update failed:', error);
                         activeInput.textContent = correctedText;
                       }
                     } else {
                       activeInput.textContent = correctedText;
                     }
                   }
                   closePopup();
                 });
               }

               // Handle copy button (for all input types)
               if (copyBtn) {
                 copyBtn.addEventListener('click', () => {
                   // Ensure the text preserves exact formatting
                   const textToCopy = correctedText.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
                   navigator.clipboard.writeText(textToCopy).then(() => {
                     // Show success feedback
                     const button = copyBtn as HTMLElement;
                     const originalText = button.textContent;
                     button.textContent = 'Copied!';
                     button.style.backgroundColor = '#4CAF50';
                     setTimeout(() => {
                       button.textContent = originalText;
                       button.style.backgroundColor = '';
                     }, 2000);
                   }).catch((error) => {
                     console.warn('Clipboard copy failed:', error);
                     // Fallback: show the text in an alert
                     alert(`Copy this text and paste it manually:\n\n${textToCopy}`);
                   });
                 });
               }

              if (closeBtn) {
                closeBtn.addEventListener('click', closePopup);
              }
            }
          }
        } catch (error: any) {
          console.error('Grammar check error:', error);
          if (popup) {
            const content = popup.querySelector('.safetyper-popup-content');
            if (content) {
              content.innerHTML = `
                <p class="error">Error checking grammar: ${escapeHtml(error.message || 'Unknown error')}</p>
                <button class="safetyper-close-btn">Close</button>
              `;

              const closeBtn = content.querySelector('.safetyper-close-btn');
              if (closeBtn) {
                closeBtn.addEventListener('click', closePopup);
              }
            }
          }
        }
      }).catch((error: any) => {
        console.error('Error getting settings:', error);
        if (popup) {
          const content = popup.querySelector('.safetyper-popup-content');
          if (content) {
            content.innerHTML = `
              <p class="error">Error accessing settings: ${escapeHtml(error.message || 'Unknown error')}</p>
              <button class="safetyper-close-btn">Close</button>
            `;

            const closeBtn = content.querySelector('.safetyper-close-btn');
            if (closeBtn) {
              closeBtn.addEventListener('click', closePopup);
            }
          }
        }
      });
    }

    // Handle input focus
    function handleFocus(e: FocusEvent) {
      const target = e.target as HTMLElement;
      if (isEditableElement(target)) {
        activeInput = target;
        createIcon();
        // Ensure icon is visible even if it was hidden
        if (iconContainer) {
          iconContainer.style.display = 'flex';
        }
        positionIcon(target);
      }
    }

    // Handle global typing detection with improved filtering and adaptive debouncing
    function handleKeyDown(e: Event) {
      const keyboardEvent = e as KeyboardEvent;

      // Skip if we're in the middle of IME composition
      if (isComposing) {
        return;
      }

      // Only process significant key events
      if (!isSignificantKeyEvent(keyboardEvent)) {
        return;
      }

      // Get the currently active element
      const activeElement = document.activeElement as HTMLElement;

      // Check if the active element is an editable element
      if (activeElement && isEditableElement(activeElement)) {
        // Track typing speed for adaptive debouncing
        const now = Date.now();
        if (lastTypingTime > 0) {
          const timeDiff = now - lastTypingTime;
          typingSpeedHistory.push(timeDiff);
          // Keep only last 10 measurements
          if (typingSpeedHistory.length > 10) {
            typingSpeedHistory.shift();
          }
        }
        lastTypingTime = now;

        // If we're not already tracking this element, set it as active
        if (activeInput !== activeElement) {
          activeInput = activeElement;
          createIcon();
        }

        // Show icon and position it near the active element with adaptive debouncing
        if (iconContainer) {
          iconContainer.style.display = 'flex';
          // Clear existing timer
          if (typingTimer) {
            clearTimeout(typingTimer);
          }
          // Use adaptive debounce time
          const debounceTime = getAdaptiveDebounceTime();
          typingTimer = window.setTimeout(() => {
            if (activeInput) {
              positionIcon(activeInput);
            }
          }, debounceTime);
        }
      }
    }

    // Handle input blur
    function handleBlur(e: FocusEvent) {
      // Check if the next focused element is another editable element
      const relatedTarget = e.relatedTarget as HTMLElement | null;
      const isSwitchingToEditable = relatedTarget ? isEditableElement(relatedTarget) : false;

      // Delay hiding to allow icon click or switching between inputs
      setTimeout(() => {
        // Only hide if we're not switching to another editable element and there's no popup
        if (!isSwitchingToEditable && !popup) {
          hideIcon();
          activeInput = null;
          // Reset cached position when hiding
          cachedPosition = null;
          lastInputRect = null;
        }
      }, 200);
    }

    // Handle IME composition events
    function handleCompositionStart() {
      isComposing = true;
    }

    function handleCompositionEnd() {
      isComposing = false;
      // Trigger position update after composition ends
      if (activeInput && iconContainer) {
        positionIcon(activeInput);
      }
    }

    // Add event listeners
    document.addEventListener('focusin', handleFocus);
    document.addEventListener('focusout', handleBlur);
    document.addEventListener('keydown', handleKeyDown);
    document.addEventListener('compositionstart', handleCompositionStart);
    document.addEventListener('compositionend', handleCompositionEnd);
    window.addEventListener('resize', repositionIconOnResize);

    // Handle dynamically added inputs
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        mutation.addedNodes.forEach((node) => {
          if (node.nodeType === 1) {
            const element = node as HTMLElement;
            if (isEditableElement(element)) {
              // New editable element added - could add specific handling here if needed
            }
          }
        });
      });
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
  },
});
